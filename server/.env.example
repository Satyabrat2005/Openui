# OpenUI Tier Enforcement Server Configuration

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
# Optional but recommended for tier caching and task queue
# If not set, server will run without caching (slower tier lookups)
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────
# Required for tier syncing from Supabase auth.users.app_metadata.tier
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─────────────────────────────────────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────────────────────────────────────
# Required for webhook processing and tier updates on subscription change

# Stripe secret key (keep secret!)
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...

# Price IDs for tiers (from Stripe Dashboard → Products)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────

# Debug mode (true/false, default false)
DEBUG=false

# Server port (default 5000)
PORT=5000

# ─────────────────────────────────────────────────────────────────────────────
# Production Settings (optional)
# ─────────────────────────────────────────────────────────────────────────────

# For Gunicorn/production deployments
# WORKERS=4
# WORKER_CLASS=sync
# WORKER_CONNECTIONS=1000
# TIMEOUT=120
