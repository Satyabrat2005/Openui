{
  "name": "openui",
  "version": "0.1.1",
  "description": "OpenUI — a macOS menu-bar AI assistant (Electron + Vite + React + TypeScript)",
  "main": "./out/main/index.js",
  "author": "OpenUI",
  "license": "MIT",
  "scripts": {
    "postinstall": "node scripts/generate-tray-icon.cjs && node scripts/convert-icon.js",
    "icons": "node scripts/generate-tray-icon.cjs && node scripts/convert-icon.js",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "build:mac": "electron-vite build && electron-builder --mac --publish never",
    "build:win": "electron-vite build && electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.openui.app",
    "productName": "OpenUI",
    "publish": {
      "provider": "github",
      "owner": "Satyabrat2005",
      "repo": "Openui"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "protocols": [
      {
        "name": "OpenUI Auth",
        "schemes": [
          "openui"
        ]
      }
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "npmRebuild": true,
    "afterSign": "scripts/notarize.js",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "protocols": [
        {
          "name": "OpenUI Auth",
          "schemes": [
            "openui"
          ]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "artifactName": "${productName}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "artifactName": "OpenUI-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "uninstallDisplayName": "OpenUI",
      "installerHeaderBitmap": "resources/installer-header.bmp",
      "installerSidebar": "resources/installer-sidebar.bmp",
      "license": "LICENSE",
      "installerLanguages": [
        "en_US"
      ],
      "language": "1033",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenUI",
      "runAfterFinish": true,
      "menuCategory": "OpenUI",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nut-tree-fork/nut-js": "^4.2.0",
    "@octokit/rest": "^20.0.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "^6.8.9",
    "gsap": "^3.12.5",
    "node-osascript": "^2.1.0",
    "ollama": "^0.5.0",
    "openai": "^4.0.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.44.0",
    "posthog-node": "^4.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^5.1.0"
  },
  "optionalDependencies": {
    "hnswlib-node": "^3.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "png2icons": "^2.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^7.3.5"
  }
}
