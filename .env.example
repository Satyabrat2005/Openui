# OpenUI environment variables — copy to `.env` and fill in real values.
# `.env` is git-ignored; NEVER commit real keys. All secrets are read in the
# Electron MAIN process only and are never exposed to the renderer.

# ── Pro tier: Anthropic (chat + read_screen vision on pro/enterprise) ─────────
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Voice transcription: OpenAI Whisper (used by all tiers for voice input) ───
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Free tier: Ollama (local model) — optional overrides ──────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:8b

# ── Enterprise tier: OpenAI-compatible endpoint (e.g. self-hosted GLM) ────────
GLM_BASE_URL=http://127.0.0.1:8080/v1
GLM_API_KEY=no-key
GLM_MODEL=glm-4

# ── Authentication: Supabase (Google OAuth via openui:// deep link) ───────────
# Project URL and anon (public) key from your Supabase project settings:
#   https://app.supabase.com → Project Settings → API
# In Supabase Auth → URL Configuration, add `openui://auth-callback` to the
# allowed redirect URLs, and enable the Google provider.
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
